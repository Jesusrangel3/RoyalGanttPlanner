# ============================================================
#  Royal Gantt Planner — Variables de Producción
#  Copia a .env.production y llena los valores ANTES de hacer build
#  NUNCA subas este archivo con valores reales a control de versiones
# ============================================================

# --- Base de Datos ---
DB_USER=royalapp
DB_PASSWORD=CONTRASEÑA_PRODUCCION_AQUI
DB_SERVER=IP_O_NOMBRE_SERVIDOR_SQL\SQLEXPRESS
DB_DATABASE=RoyalGanttPlanner
DB_PORT=1433
DB_ENCRYPT=true

# --- JWT (usa un valor diferente al de desarrollo) ---
# Genera: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=SECRETO_LARGO_ALEATORIO_64_BYTES_EN_HEX

# --- WebSocket ---
SOCKET_PORT=3001
SOCKET_ALLOWED_ORIGINS=https://tudominio.com

# --- CORS ---
CORS_ALLOWED_ORIGINS=https://tudominio.com

# --- Email (recomendado en producción) ---
SMTP_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=notificaciones@royaltransports.com.mx
SMTP_PASS=APP_PASSWORD_AQUI
SMTP_FROM=Royal Gantt Planner <notificaciones@royaltransports.com.mx>

# --- Subida de archivos ---
UPLOAD_DIR=./public/uploads
UPLOAD_MAX_MB=5

# --- URL pública de la aplicación ---
NEXT_PUBLIC_APP_URL=https://tudominio.com
