# ============================================================
#  Royal Gantt Planner — Variables de Entorno
#  Copia este archivo a .env.local y llena los valores reales
#  NUNCA subas .env.local a control de versiones
# ============================================================

# --- Base de Datos SQL Server ---
DB_USER=royalapp
DB_PASSWORD=TU_CONTRASEÑA_SEGURA_AQUI
DB_SERVER=localhost\SQLEXPRESS
DB_DATABASE=RoyalGanttPlanner
DB_PORT=1433
# Recomendado: true en producción (requiere certificado o trustServerCertificate=true en db.ts)
DB_ENCRYPT=false

# --- JWT (sesiones de usuario) ---
# Genera con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=GENERA_UN_SECRETO_LARGO_Y_ALEATORIO_AQUI

# --- WebSocket ---
SOCKET_PORT=3001
# Orígenes permitidos separados por coma
SOCKET_ALLOWED_ORIGINS=http://localhost:3000

# --- CORS (API Next.js) ---
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Notificaciones por correo (opcional) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASS=tu-app-password-de-gmail
# SMTP_FROM=Royal Gantt Planner <no-reply@royaltransports.com.mx>
# SMTP_ENABLED=false

# --- Subida de archivos ---
UPLOAD_DIR=./public/uploads
UPLOAD_MAX_MB=5
